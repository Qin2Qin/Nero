XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_TENANT_ID=
XERO_REDIRECT_URI=http://localhost:8000/auth/callback
# Optional: import existing OAuth tokens into local SQLite with scripts/import_xero_tokens.py.
XERO_ACCESS_TOKEN=
XERO_REFRESH_TOKEN=
XERO_TOKEN_EXPIRES_AT=
XERO_TOKEN_EXPIRES_IN=1800
# Optional: required only when /webhooks/xero is configured in Xero Developer Centre.
XERO_WEBHOOK_KEY=
# Set true only after Xero Developer Centre App Store subscription/webhook setup is complete.
XERO_APP_STORE_SUBSCRIPTIONS_CONFIGURED=false
# Optional app-runtime AI polishing. OPENROUTER_MODEL must be a free model ending in :free.
NERO_AI_COPY_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
DEMO_MODE=true
CASH_FLOOR=5000
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000
